---
import "../styles/global.css"

export interface Props {
	title?: string;
}

const { title = "Espace29" } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link href="/src/styles/legacy.css" rel="stylesheet" />
		<title>{title}</title>
	</head>
	<body>
		<div>{title}</div>
		<slot />
	</body>
</html>
