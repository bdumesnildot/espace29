---
import "../styles/global.css"

import Navbar from "../components/navigation/Navbar.astro"

export interface Props {
  title?: string
}

const { title = "Espace29" } = Astro.props
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body
    class="bg-gray-100 m-0 p-0 h-screen w-screen font-sans text-gray-900 flex flex-col"
  >
    <header>
      <Navbar />
    </header>
    <div class="grow">
      <slot />
    </div>
  </body>
</html>
