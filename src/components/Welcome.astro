---

---

<div class="p-8 space-y-8">
	<h1 class="text-3xl font-bold mb-8 text-gray-900">Eina Font Family Diagnosis</h1>
	
	<!-- Font Loading Test -->
	<section class="bg-yellow-50 p-6 rounded-lg">
		<h2 class="text-xl font-semibold text-gray-800 mb-4">🔍 Font Loading Test</h2>
		<p class="text-sm text-gray-600 mb-4">If fonts are loading correctly, you should see different letter shapes (especially 'a', 'g', 'R')</p>
		
		<div class="space-y-3 text-6xl leading-tight">
			<div class="font-eina01 text-gray-800">Eina01: Rag</div>
			<div class="font-eina02 text-blue-800">Eina02: Rag</div>
			<div class="font-eina03 text-green-800">Eina03: Rag</div>
			<div class="font-eina04 text-purple-800">Eina04: Rag</div>
		</div>
	</section>

	<!-- Fallback Detection -->
	<section class="bg-red-50 p-6 rounded-lg">
		<h2 class="text-xl font-semibold text-gray-800 mb-4">⚠️ Fallback Font Detection</h2>
		<p class="text-sm text-gray-600 mb-4">These should look different from system fonts if Eina is loading:</p>
		
		<div class="space-y-2 text-2xl">
			<div class="font-eina01">Eina01: The quick brown fox (should be Eina01)</div>
			<div style="font-family: system-ui">System: The quick brown fox (system fallback)</div>
			<div style="font-family: ui-sans-serif">UI Sans: The quick brown fox (ui-sans fallback)</div>
		</div>
	</section>

	<!-- Critical Letter Comparison -->
	<section class="space-y-6">
		<h2 class="text-xl font-semibold text-gray-800 border-b pb-2">🔤 Critical Letter Forms (should be very different)</h2>
		<div class="grid grid-cols-2 gap-8">
			<div>
				<h3 class="font-semibold mb-3">Lowercase Critical Letters</h3>
				<div class="space-y-2 text-8xl leading-none">
					<div class="font-eina01 text-gray-800">a g</div>
					<div class="font-eina02 text-blue-800">a g</div>
					<div class="font-eina03 text-green-800">a g</div>
					<div class="font-eina04 text-purple-800">a g</div>
				</div>
			</div>
			<div>
				<h3 class="font-semibold mb-3">Uppercase Critical Letters</h3>
				<div class="space-y-2 text-8xl leading-none">
					<div class="font-eina01 text-gray-800">R Q</div>
					<div class="font-eina02 text-blue-800">R Q</div>
					<div class="font-eina03 text-green-800">R Q</div>
					<div class="font-eina04 text-purple-800">R Q</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Browser Dev Tools Check -->
	<section class="bg-blue-50 p-6 rounded-lg">
		<h2 class="text-xl font-semibold text-gray-800 mb-4">🔧 Browser Dev Tools Check</h2>
		<p class="text-sm text-gray-600 mb-2">Open browser dev tools and:</p>
		<ol class="list-decimal list-inside text-sm text-gray-700 space-y-1">
			<li>Right-click on any Eina text below → Inspect</li>
			<li>Look at the Computed tab → Check font-family value</li>
			<li>Go to Network tab → Reload page → Filter by "Font" → Check if TTF files load</li>
			<li>In Console, run: <code class="bg-gray-200 px-1 rounded">document.fonts.ready.then(() => console.log('Fonts loaded:', document.fonts))</code></li>
		</ol>
		
		<div class="mt-4 space-y-2">
			<div class="font-eina01 text-2xl" id="test-eina01">Test Eina01 - Right click to inspect</div>
			<div class="font-eina02 text-2xl" id="test-eina02">Test Eina02 - Right click to inspect</div>
			<div class="font-eina03 text-2xl" id="test-eina03">Test Eina03 - Right click to inspect</div>
			<div class="font-eina04 text-2xl" id="test-eina04">Test Eina04 - Right click to inspect</div>
		</div>
	</section>

	<!-- Possible Issues -->
	<section class="bg-gray-50 p-6 rounded-lg">
		<h2 class="text-xl font-semibold text-gray-800 mb-4">🚨 Possible Issues</h2>
		<div class="space-y-3 text-sm text-gray-700">
			<div><strong>1. Font Files Are Identical:</strong> The TTF files might be the same font with different filenames</div>
			<div><strong>2. Font Loading Failed:</strong> TTF files might be corrupted or not accessible</div>
			<div><strong>3. Browser Cache:</strong> Old fonts cached, try hard refresh (Ctrl+Shift+R)</div>
			<div><strong>4. Path Issues:</strong> Font URLs might be incorrect (check Network tab)</div>
			<div><strong>5. Font Format:</strong> Some browsers have TTF loading issues</div>
		</div>
	</section>

	<!-- Quick Fix Test -->
	<section class="bg-green-50 p-6 rounded-lg">
		<h2 class="text-xl font-semibold text-gray-800 mb-4">⚡ Quick Fix Test</h2>
		<p class="text-sm text-gray-600 mb-4">Testing with direct font-family CSS (bypasses Tailwind):</p>
		
		<div class="space-y-2 text-3xl">
			<div style="font-family: 'Eina01', sans-serif;">Direct Eina01: Typography</div>
			<div style="font-family: 'Eina02', sans-serif;">Direct Eina02: Typography</div>
			<div style="font-family: 'Eina03', sans-serif;">Direct Eina03: Typography</div>
			<div style="font-family: 'Eina04', sans-serif;">Direct Eina04: Typography</div>
		</div>
	</section>
</div>

