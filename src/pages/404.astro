---
import Layout from "../layouts/Layout.astro"
---

<Layout title="e29 | 404">
  <div class="h-full flex flex-col items-center justify-center">
    <h1 class="text-4xl font-bold mb-8 text-gray-900 font-eina02">
      404 - Page Not Found
    </h1>
    <p class="text-xl text-gray-700 font-eina02 mb-4">
      Oops! The page you're looking for doesn't exist.
    </p>
    <a href="/" class="text-sky-600 hover:underline font-eina02"
      >Return to Home</a
    >
  </div>
</Layout>
