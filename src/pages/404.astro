---
import Button from "@components/ui/button/Button.astro"
import Layout from "@layouts/Layout.astro"
---

<Layout title="e29 | Page non trouvée">
  <main class="h-full flex items-center justify-center px-6 py-12">
    <div class="max-w-2xl mx-auto text-center">
      <!-- Error Code -->
      <div class="mb-8">
        <h1 class="text-8xl font-eina01 font-semibold text-gray-900 mb-4">
          404
        </h1>
        <div class="w-24 h-px bg-gray-300 mx-auto mb-8"></div>
      </div>

      <!-- Error Message -->
      <div class="mb-12">
        <h2 class="text-4xl font-eina02 font-medium text-gray-900 mb-6">
          Page non trouvée
        </h2>
        <p class="text-xl font-eina03 leading-relaxed text-gray-700 mb-6">
          Désolé, la page que vous cherchez n'existe pas ou a été déplacée.
        </p>
        <p class="text-lg font-eina03 text-gray-600">
          Vérifiez l'URL ou retournez à l'accueil pour découvrir notre
          programmation artistique.
        </p>
      </div>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/" class="inline-block">
          <Button intent="primary" size="large">
            Retour à l'accueil
          </Button>
        </a>
        <a href="/agenda" class="inline-block">
          <Button intent="secondary" size="large">
            Voir l'agenda
          </Button>
        </a>
      </div>
    </div>
  </main>
</Layout>
