---
import Button from '@components/ui/button/Button.astro'
import Layout from '@layouts/Layout.astro'
---

<Layout title="e29 | Page non trouvée">
  <main class="flex h-full items-center justify-center px-6 py-12">
    <div class="mx-auto max-w-2xl text-center">
      <!-- Error Code -->
      <div class="mb-8">
        <h1 class="font-eina01 mb-4 text-8xl font-semibold text-gray-900">
          404
        </h1>
        <div class="mx-auto mb-8 h-px w-24 bg-gray-300"></div>
      </div>

      <!-- Error Message -->
      <div class="mb-12">
        <h2 class="font-eina02 mb-6 text-4xl font-medium text-gray-900">
          Page non trouvée
        </h2>
        <p class="font-eina03 mb-6 text-xl leading-relaxed text-gray-700">
          Désolé, la page que vous cherchez n'existe pas ou a été déplacée.
        </p>
        <p class="font-eina03 text-lg text-gray-600">
          Vérifiez l'URL ou retournez à l'accueil pour découvrir notre
          programmation artistique.
        </p>
      </div>

      <!-- Actions -->
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/" class="inline-block">
          <Button intent="primary" size="large"> Retour à l'accueil </Button>
        </a>
        <a href="/agenda" class="inline-block">
          <Button intent="secondary" size="large"> Voir l'agenda </Button>
        </a>
      </div>
    </div>
  </main>
</Layout>
