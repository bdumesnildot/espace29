---
import Layout from "@layouts/Layout.astro"
---

<Layout title="e29 | Mentions légales">
  <main class="max-w-7xl mx-auto px-6 py-12">
    <!-- Header -->
    <header class="mb-16 text-center">
      <h1
        class="text-6xl sm:text-8xl text-gray-900 font-eina01 font-semibold pt-4 pb-8 sm:pt-20 sm:pb-40 w-full"
      >
        Mentions légales
      </h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        Informations légales et réglementaires concernant le site Espace29
      </p>
    </header>

    <!-- Content -->
    <div class="max-w-4xl mx-auto space-y-16">
      <!-- Éditeur du site -->
      <section>
        <h2 class="text-3xl sm:text-5xl font-eina02 font-semibold mb-8">
          Éditeur du site
        </h2>
        <div>
          <div class="space-y-4 text-lg font-eina03 text-gray-700">
            <p><strong class="text-gray-900">Nom :</strong> Espace29</p>
            <p>
              <strong class="text-gray-900">Forme juridique :</strong> Association
              déclarée
            </p>
            <p>
              <strong class="text-gray-900">Adresse :</strong> 29 RUE FERNAND MARIN
              33000 BORDEAUX
            </p>
            <p>
              <strong class="text-gray-900">Email :</strong> espace29@gmail.com
            </p>
            <p>
              <strong class="text-gray-900">SIRET :</strong> 449 418 037 00031
            </p>
            <p>
              <strong class="text-gray-900">Directeur de publication :</strong> Mario
              Sardo
            </p>
          </div>
        </div>
      </section>

      <!-- Hébergement -->
      <section>
        <h2 class="text-3xl sm:text-5xl font-eina02 font-semibold mb-8">
          Hébergement
        </h2>
        <div>
          <div class="space-y-4 text-lg font-eina03 text-gray-700">
            <p>
              <strong class="text-gray-900">Hébergeur :</strong> Vercel Inc.
            </p>
            <p>
              <strong class="text-gray-900">Adresse :</strong> 340 S Lemon Ave #4133,
              Walnut, CA 91789
            </p>
            <p>
              <strong class="text-gray-900">Téléphone :</strong> (559) 288-7060
            </p>
            <p>
              <strong class="text-gray-900">Adresse e-mail :</strong> privacy@vercel.com
            </p>
          </div>
        </div>
      </section>

      <!-- Propriété intellectuelle -->
      <section>
        <h2 class="text-3xl sm:text-5xl font-eina02 font-semibold mb-8">
          Droit d'auteur et propriété intellectuelle
        </h2>
        <div>
          <div
            class="space-y-6 text-lg font-eina03 text-gray-700 leading-relaxed"
          >
            <p>
              Tous les contenus de ce site (textes, images, vidéos, etc.) sont
              protégés par le droit d'auteur et sont la propriété exclusive de
              L'Espace29, sauf indication contraire. Toute reproduction,
              distribution ou utilisation non autorisée des contenus est
              strictement interdite.
            </p>
          </div>
        </div>
      </section>

      <!-- Données personnelles -->
      <section>
        <h2 class="text-3xl sm:text-5xl font-eina02 font-semibold mb-8">
          Protection des données personnelles
        </h2>
        <div>
          <div
            class="space-y-6 text-lg font-eina03 text-gray-700 leading-relaxed"
          >
            <p>Le site ne collecte pas de données personnelles.</p>
          </div>
        </div>
      </section>

      <!-- Responsabilité -->
      <section>
        <h2 class="text-3xl sm:text-5xl font-eina02 font-semibold mb-8">
          Responsabilité
        </h2>
        <div>
          <div
            class="space-y-6 text-lg font-eina03 text-gray-700 leading-relaxed"
          >
            <p>
              Nous nous efforçons de fournir des informations précises et à jour
              sur ce site, mais nous ne pouvons garantir l'exactitude de toutes
              les informations. Nous déclinons toute responsabilité en cas
              d'erreurs ou d'omissions dans les contenus du site.
            </p>
          </div>
        </div>
      </section>

      <!-- Droit applicable -->
      <section>
        <h2 class="text-3xl sm:text-5xl font-eina02 font-semibold mb-8">
          Droit applicable
        </h2>
        <div>
          <p class="text-lg font-eina03 text-gray-700 leading-relaxed">
            Ce site est régi par les lois en vigueur en France. Tout litige
            relatif à ce site sera soumis à la juridiction exclusive des
            tribunaux compétents de Bordeaux.
          </p>
        </div>
      </section>
    </div>

    <!-- Footer -->
    <footer class="border-t border-gray-200 pt-12 mt-20 text-center">
      <p class="text-gray-600 font-eina03">
        Dernière mise à jour : octobre 2025
      </p>
    </footer>
  </main>
</Layout>
