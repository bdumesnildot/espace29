---
import Layout from "../../layouts/Layout.astro"
---

<Layout title="e29 | Design System">
  <main class="max-w-7xl mx-auto px-6 py-12">
    <!-- Header -->
    <header class="mb-16 text-center">
      <h1 class="text-8xl font-eina01 font-semibold mb-4">Design System</h1>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        A minimal design system for Espace29 — a white canvas approach that allows artist content to be the focus.
        Built with restraint using gray scale tones and the sophisticated Eina typography collection.
      </p>
    </header>

    <!-- Navigation -->
    <nav class="mb-12 border-b border-gray-100 pb-6">
      <ul class="flex flex-wrap gap-6 justify-center text-lg">
        <li><a href="#philosophy" class="hover:text-gray-600 transition-colors">Philosophy</a></li>
        <li><a href="#typography" class="hover:text-gray-600 transition-colors">Typography</a></li>
        <li><a href="#colors" class="hover:text-gray-600 transition-colors">Colors</a></li>
        <li><a href="#spacing" class="hover:text-gray-600 transition-colors">Spacing</a></li>
        <li><a href="#layout" class="hover:text-gray-600 transition-colors">Layout</a></li>
        <li><a href="#components" class="hover:text-gray-600 transition-colors">Components</a></li>
        <li><a href="#interactions" class="hover:text-gray-600 transition-colors">Interactions</a></li>
      </ul>
    </nav>

    <!-- White Canvas Philosophy Section -->
    <section id="philosophy" class="mb-20">
      <h2 class="text-5xl font-eina02 font-semibold mb-12">White Canvas Philosophy</h2>
      
      <div class="max-w-4xl mx-auto">
        <div class="p-8 bg-gray-50/50 rounded-lg border border-gray-100">
          <h3 class="text-3xl font-eina03 font-medium mb-6">Restraint as Design</h3>
          <p class="text-lg font-eina03 leading-relaxed text-gray-700 mb-6">
            Espace29 embraces the concept of a white canvas — a purposefully minimal interface that serves as the foundation for artistic expression. 
            Our design system prioritizes restraint over ornamentation, creating space for artist content to flourish without visual competition.
          </p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-8">
            <div>
              <h4 class="text-xl font-eina04 font-semibold mb-4 text-gray-900">Core Principles</h4>
              <ul class="space-y-3 text-gray-700 font-eina03">
                <li>• <strong>Minimalism:</strong> Less interface, more content</li>
                <li>• <strong>Neutrality:</strong> Grayscale palette that doesn't compete</li>
                <li>• <strong>Clarity:</strong> Clean typography hierarchy</li>
                <li>• <strong>Flexibility:</strong> Adapts to any artistic medium</li>
              </ul>
            </div>
            <div>
              <h4 class="text-xl font-eina04 font-semibold mb-4 text-gray-900">Content First</h4>
              <ul class="space-y-3 text-gray-700 font-eina03">
                <li>• Artist work is the primary visual element</li>
                <li>• UI elements fade into the background</li>
                <li>• Color usage is deliberate and minimal</li>
                <li>• White space creates breathing room</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Typography Section -->
    <section id="typography" class="mb-20">
      <h2 class="text-5xl font-eina02 font-semibold mb-12">Typography</h2>
      
      <!-- Font Families -->
      <div class="mb-16">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Font Families</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="p-6 bg-white rounded-lg border border-gray-200 shadow-sm">
            <h4 class="text-xl font-semibold mb-4">Eina01 - Rational Style</h4>
            <p class="font-eina01 text-4xl mb-4">Typography Sample</p>
            <p class="font-eina01 text-lg mb-2">The quick brown fox jumps over the lazy dog</p>
            <p class="text-sm text-gray-600">Rational, structured design for display and hero text</p>
            <code class="text-xs font-mono bg-gray-100 px-2 py-1 rounded">font-eina01</code>
          </div>
          <div class="p-6 bg-white rounded-lg border border-gray-200 shadow-sm">
            <h4 class="text-xl font-semibold mb-4">Eina02 - Humanist Style</h4>
            <p class="font-eina02 text-4xl mb-4">Typography Sample</p>
            <p class="font-eina02 text-lg mb-2">The quick brown fox jumps over the lazy dog</p>
            <p class="text-sm text-gray-600">Warm, humanist approach for headings and titles</p>
            <code class="text-xs font-mono bg-gray-100 px-2 py-1 rounded">font-eina02</code>
          </div>
          <div class="p-6 bg-white rounded-lg border border-gray-200 shadow-sm">
            <h4 class="text-xl font-semibold mb-4">Eina03 - Geometric Style</h4>
            <p class="font-eina03 text-4xl mb-4">Typography Sample</p>
            <p class="font-eina03 text-lg mb-2">The quick brown fox jumps over the lazy dog</p>
            <p class="text-sm text-gray-600">Clean, geometric precision for body text and content</p>
            <code class="text-xs font-mono bg-gray-100 px-2 py-1 rounded">font-eina03</code>
          </div>
          <div class="p-6 bg-white rounded-lg border border-gray-200 shadow-sm">
            <h4 class="text-xl font-semibold mb-4">Eina04 - Industrial Style</h4>
            <p class="font-eina04 text-4xl mb-4">Typography Sample</p>
            <p class="font-eina04 text-lg mb-2">The quick brown fox jumps over the lazy dog</p>
            <p class="text-sm text-gray-600">Strong, industrial efficiency for UI elements</p>
            <code class="text-xs font-mono bg-gray-100 px-2 py-1 rounded">font-eina04</code>
          </div>
        </div>
      </div>

      <!-- Font Sizes -->
      <div class="mb-16">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Typography Scale</h3>
        <div class="space-y-6">
          <div class="flex items-center gap-6 p-4 border-l-4 border-gray-900">
            <span class="text-8xl font-eina01 font-semibold">text-8xl</span>
            <div>
              <p class="font-mono text-sm">120px, font-weight: 600</p>
              <p class="text-gray-600">Hero headings</p>
            </div>
          </div>
          <div class="flex items-center gap-6 p-4 border-l-4 border-gray-700">
            <span class="text-7xl font-eina01 font-semibold">text-7xl</span>
            <div>
              <p class="font-mono text-sm">100px, font-weight: 600</p>
              <p class="text-gray-600">Large display headings</p>
            </div>
          </div>
          <div class="flex items-center gap-6 p-4 border-l-4 border-gray-500">
            <span class="text-6xl font-eina02">text-6xl</span>
            <div>
              <p class="font-mono text-sm">80px, font-weight: 400</p>
              <p class="text-gray-600">Section headings</p>
            </div>
          </div>
          <div class="flex items-center gap-6 p-4 border-l-4 border-gray-400">
            <span class="text-5xl font-eina02">text-5xl</span>
            <div>
              <p class="font-mono text-sm">60px, font-weight: 400</p>
              <p class="text-gray-600">Major headings</p>
            </div>
          </div>
          <div class="flex items-center gap-6 p-4 border-l-4 border-gray-300">
            <span class="text-4xl font-eina03">text-4xl</span>
            <div>
              <p class="font-mono text-sm">35px, line-height: 1.2, font-weight: 400</p>
              <p class="text-gray-600">Content headings</p>
            </div>
          </div>
          <div class="flex items-center gap-6 p-4 border-l-4 border-gray-200">
            <span class="text-3xl font-eina03">text-3xl</span>
            <div>
              <p class="font-mono text-sm">30px, font-weight: 400</p>
              <p class="text-gray-600">Subheadings</p>
            </div>
          </div>
          <div class="flex items-center gap-6 p-4 border-l-4 border-gray-200">
            <span class="text-2xl font-eina03">text-2xl</span>
            <div>
              <p class="font-mono text-sm">25px, font-weight: 400</p>
              <p class="text-gray-600">Card titles</p>
            </div>
          </div>
          <div class="flex items-center gap-6 p-4 border-l-4 border-gray-100">
            <span class="text-xl font-eina03">text-xl</span>
            <div>
              <p class="font-mono text-sm">20px, font-weight: 400</p>
              <p class="text-gray-600">Large body text</p>
            </div>
          </div>
          <div class="flex items-center gap-6 p-4 border-l-4 border-gray-100">
            <span class="text-lg font-eina03">text-lg</span>
            <div>
              <p class="font-mono text-sm">15px, line-height: 1.6, font-weight: 400</p>
              <p class="text-gray-600">Body text, paragraphs</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Font Weights -->
      <div class="mb-16">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Font Weights</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="p-4 bg-white rounded border border-gray-200">
            <p class="text-xl font-light font-eina03 mb-2">Light</p>
            <code class="text-sm">font-light (300)</code>
          </div>
          <div class="p-4 bg-white rounded border border-gray-200">
            <p class="text-xl font-normal font-eina03 mb-2">Regular</p>
            <code class="text-sm">font-normal (400)</code>
          </div>
          <div class="p-4 bg-white rounded border border-gray-200">
            <p class="text-xl font-semibold font-eina03 mb-2">Semibold</p>
            <code class="text-sm">font-semibold (600)</code>
          </div>
          <div class="p-4 bg-white rounded border border-gray-200">
            <p class="text-xl font-bold font-eina03 mb-2">Bold</p>
            <code class="text-sm">font-bold (700)</code>
          </div>
        </div>
      </div>
    </section>

    <!-- Colors Section -->
    <section id="colors" class="mb-20">
      <h2 class="text-5xl font-eina02 font-semibold mb-12">Colors</h2>
      
      <div class="mb-8">
        <p class="text-lg font-eina03 text-gray-600 max-w-3xl">
          Our color palette embraces restraint. The foundation is built on grayscale tones that provide structure without distraction, 
          with a single accent color reserved for critical interactions only.
        </p>
      </div>
      
      <!-- Primary Colors -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Grayscale Foundation</h3>
        <div class="grid grid-cols-2 md:grid-cols-5 lg:grid-cols-10 gap-4">
          <div class="text-center">
            <div class="w-full h-20 bg-white rounded mb-2 border border-gray-200"></div>
            <p class="text-sm font-mono">white</p>
            <p class="text-xs text-gray-500">Canvas</p>
          </div>
          <div class="text-center">
            <div class="w-full h-20 bg-gray-50 rounded mb-2 border"></div>
            <p class="text-sm font-mono">gray-50</p>
            <p class="text-xs text-gray-500">Background</p>
          </div>
          <div class="text-center">
            <div class="w-full h-20 bg-gray-100 rounded mb-2"></div>
            <p class="text-sm font-mono">gray-100</p>
            <p class="text-xs text-gray-500">Subtle</p>
          </div>
          <div class="text-center">
            <div class="w-full h-20 bg-gray-200 rounded mb-2"></div>
            <p class="text-sm font-mono">gray-200</p>
            <p class="text-xs text-gray-500">Borders</p>
          </div>
          <div class="text-center">
            <div class="w-full h-20 bg-gray-300 rounded mb-2"></div>
            <p class="text-sm font-mono">gray-300</p>
            <p class="text-xs text-gray-500">Dividers</p>
          </div>
          <div class="text-center">
            <div class="w-full h-20 bg-gray-400 rounded mb-2"></div>
            <p class="text-sm font-mono">gray-400</p>
            <p class="text-xs text-gray-500">Placeholder</p>
          </div>
          <div class="text-center">
            <div class="w-full h-20 bg-gray-500 rounded mb-2"></div>
            <p class="text-sm font-mono text-white">gray-500</p>
            <p class="text-xs text-gray-500">Inactive</p>
          </div>
          <div class="text-center">
            <div class="w-full h-20 bg-gray-600 rounded mb-2"></div>
            <p class="text-sm font-mono text-white">gray-600</p>
            <p class="text-xs text-gray-500">Secondary</p>
          </div>
          <div class="text-center">
            <div class="w-full h-20 bg-gray-700 rounded mb-2"></div>
            <p class="text-sm font-mono text-white">gray-700</p>
            <p class="text-xs text-gray-500">Body text</p>
          </div>
          <div class="text-center">
            <div class="w-full h-20 bg-gray-900 rounded mb-2"></div>
            <p class="text-sm font-mono text-white">gray-900</p>
            <p class="text-xs text-gray-500">Headings</p>
          </div>
        </div>
      </div>

      <!-- Minimal Accent -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Minimal Accent</h3>
        <div class="max-w-md">
          <div class="p-6 bg-gray-50 rounded-lg border border-gray-100">
            <h4 class="text-lg font-semibold mb-4 text-gray-900">Single Accent Color</h4>
            <div class="flex items-center gap-4 mb-4">
              <div class="w-16 h-16 bg-gray-900 rounded"></div>
              <div>
                <p class="text-sm font-mono">gray-900</p>
                <p class="text-xs text-gray-600">For critical actions and focus states only</p>
              </div>
            </div>
            <p class="text-sm text-gray-600 font-eina03">
              Used sparingly for essential interactions: form focus states, primary buttons, and active navigation items.
            </p>
          </div>
        </div>
      </div>

      <!-- Usage Guidelines -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Color Usage Guidelines</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="p-6 bg-white border border-gray-100 rounded-lg">
            <h4 class="text-lg font-semibold mb-3 text-gray-900">Background Layers</h4>
            <ul class="text-sm space-y-2 text-gray-700 font-eina03">
              <li>• <code class="text-xs bg-gray-100 px-1 rounded">white</code> - Main canvas</li>
              <li>• <code class="text-xs bg-gray-100 px-1 rounded">gray-50</code> - Sections</li>
              <li>• <code class="text-xs bg-gray-100 px-1 rounded">gray-100</code> - Cards</li>
            </ul>
          </div>
          <div class="p-6 bg-white border border-gray-100 rounded-lg">
            <h4 class="text-lg font-semibold mb-3 text-gray-900">Text Hierarchy</h4>
            <ul class="text-sm space-y-2 text-gray-700 font-eina03">
              <li>• <code class="text-xs bg-gray-100 px-1 rounded">gray-900</code> - Headings</li>
              <li>• <code class="text-xs bg-gray-100 px-1 rounded">gray-700</code> - Body text</li>
              <li>• <code class="text-xs bg-gray-100 px-1 rounded">gray-500</code> - Meta text</li>
            </ul>
          </div>
          <div class="p-6 bg-white border border-gray-100 rounded-lg">
            <h4 class="text-lg font-semibold mb-3 text-gray-900">Interface Elements</h4>
            <ul class="text-sm space-y-2 text-gray-700 font-eina03">
              <li>• <code class="text-xs bg-gray-100 px-1 rounded">gray-200</code> - Borders</li>
              <li>• <code class="text-xs bg-gray-100 px-1 rounded">gray-300</code> - Dividers</li>
              <li>• <code class="text-xs bg-gray-100 px-1 rounded">gray-900</code> - Accents</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Spacing Section -->
    <section id="spacing" class="mb-20">
      <h2 class="text-5xl font-eina02 font-semibold mb-12">Spacing</h2>
      
      <!-- Spacing Scale -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Spacing Scale</h3>
        <div class="space-y-4">
          <div class="flex items-center gap-4">
            <div class="w-4 h-4 bg-gray-900"></div>
            <code class="font-mono text-sm w-16">space-x-1</code>
            <span class="text-gray-600">0.25rem (4px)</span>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-8 h-4 bg-gray-900"></div>
            <code class="font-mono text-sm w-16">space-x-2</code>
            <span class="text-gray-600">0.5rem (8px)</span>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-12 h-4 bg-gray-900"></div>
            <code class="font-mono text-sm w-16">space-x-3</code>
            <span class="text-gray-600">0.75rem (12px)</span>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-16 h-4 bg-gray-900"></div>
            <code class="font-mono text-sm w-16">space-x-4</code>
            <span class="text-gray-600">1rem (16px)</span>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-20 h-4 bg-gray-900"></div>
            <code class="font-mono text-sm w-16">space-x-5</code>
            <span class="text-gray-600">1.25rem (20px)</span>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-24 h-4 bg-gray-900"></div>
            <code class="font-mono text-sm w-16">space-x-6</code>
            <span class="text-gray-600">1.5rem (24px)</span>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-32 h-4 bg-gray-900"></div>
            <code class="font-mono text-sm w-16">space-x-8</code>
            <span class="text-gray-600">2rem (32px)</span>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-40 h-4 bg-gray-900"></div>
            <code class="font-mono text-sm w-16">space-x-10</code>
            <span class="text-gray-600">2.5rem (40px)</span>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-48 h-4 bg-gray-900"></div>
            <code class="font-mono text-sm w-16">space-x-12</code>
            <span class="text-gray-600">3rem (48px)</span>
          </div>
        </div>
      </div>

      <!-- Common Spacing Patterns -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Common Spacing Patterns</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="p-6 bg-white rounded-lg border border-gray-200 shadow-sm">
            <h4 class="text-xl font-semibold mb-4">Component Spacing</h4>
            <ul class="space-y-2 font-mono text-sm">
              <li>p-4, p-6 - Internal padding</li>
              <li>mb-4, mb-6, mb-8 - Element separation</li>
              <li>gap-4, gap-6 - Grid/flex gaps</li>
            </ul>
          </div>
          <div class="p-6 bg-white rounded-lg border border-gray-200 shadow-sm">
            <h4 class="text-xl font-semibold mb-4">Layout Spacing</h4>
            <ul class="space-y-2 font-mono text-sm">
              <li>px-6, py-12 - Page margins</li>
              <li>mb-12, mb-16, mb-20 - Section spacing</li>
              <li>max-w-7xl mx-auto - Content centering</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Layout Section -->
    <section id="layout" class="mb-20">
      <h2 class="text-5xl font-eina02 font-semibold mb-12">Layout</h2>
      
      <!-- Container Examples -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Containers</h3>
        <div class="space-y-6">
          <div class="border border-gray-300 rounded p-4">
            <code class="text-sm font-mono mb-2 block">max-w-7xl mx-auto px-6</code>
            <div class="max-w-7xl mx-auto px-6 bg-gray-50 border border-gray-200 p-4 rounded">
              Main content container (1280px max width)
            </div>
          </div>
          <div class="border border-gray-300 rounded p-4">
            <code class="text-sm font-mono mb-2 block">max-w-4xl mx-auto</code>
            <div class="max-w-4xl mx-auto bg-gray-100 border border-gray-200 p-4 rounded">
              Article/content container (896px max width)
            </div>
          </div>
          <div class="border border-gray-300 rounded p-4">
            <code class="text-sm font-mono mb-2 block">max-w-2xl mx-auto</code>
            <div class="max-w-2xl mx-auto bg-gray-200 border border-gray-300 p-4 rounded">
              Text content container (672px max width)
            </div>
          </div>
        </div>
      </div>

      <!-- Grid Examples -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Grid Layouts</h3>
        <div class="space-y-8">
          <div>
            <code class="text-sm font-mono mb-4 block">grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6</code>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              <div class="bg-white border border-gray-200 shadow-sm p-4 rounded text-center">Item 1</div>
              <div class="bg-white border border-gray-200 shadow-sm p-4 rounded text-center">Item 2</div>
              <div class="bg-white border border-gray-200 shadow-sm p-4 rounded text-center">Item 3</div>
              <div class="bg-white border border-gray-200 shadow-sm p-4 rounded text-center">Item 4</div>
              <div class="bg-white border border-gray-200 shadow-sm p-4 rounded text-center">Item 5</div>
              <div class="bg-white border border-gray-200 shadow-sm p-4 rounded text-center">Item 6</div>
            </div>
          </div>
          <div>
            <code class="text-sm font-mono mb-4 block">grid grid-cols-2 md:grid-cols-4 gap-4</code>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <div class="bg-white border border-gray-200 shadow-sm p-4 rounded text-center">Card 1</div>
              <div class="bg-white border border-gray-200 shadow-sm p-4 rounded text-center">Card 2</div>
              <div class="bg-white border border-gray-200 shadow-sm p-4 rounded text-center">Card 3</div>
              <div class="bg-white border border-gray-200 shadow-sm p-4 rounded text-center">Card 4</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Flex Examples -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Flex Layouts</h3>
        <div class="space-y-6">
          <div>
            <code class="text-sm font-mono mb-4 block">flex justify-between items-center</code>
            <div class="flex justify-between items-center bg-white border border-gray-200 p-4 rounded">
              <span>Left content</span>
              <span>Right content</span>
            </div>
          </div>
          <div>
            <code class="text-sm font-mono mb-4 block">flex flex-col md:flex-row gap-6</code>
            <div class="flex flex-col md:flex-row gap-6">
              <div class="bg-gray-50 border border-gray-200 p-4 rounded flex-1">Flexible item 1</div>
              <div class="bg-gray-50 border border-gray-200 p-4 rounded flex-1">Flexible item 2</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Components Section -->
    <section id="components" class="mb-20">
      <h2 class="text-5xl font-eina02 font-semibold mb-12">Components</h2>
      
      <!-- Buttons -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Buttons</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div>
            <h4 class="text-lg font-semibold mb-4">Primary Buttons</h4>
            <div class="space-y-4">
              <button class="bg-gray-900 hover:bg-gray-800 text-white font-eina04 font-semibold py-3 px-6 rounded-lg transition-colors">
                Primary Button
              </button>
              <div class="text-sm font-mono text-gray-600">
                bg-gray-900 hover:bg-gray-800 text-white font-eina04 font-semibold py-3 px-6 rounded-lg transition-colors
              </div>
            </div>
          </div>
          <div>
            <h4 class="text-lg font-semibold mb-4">Secondary Buttons</h4>
            <div class="space-y-4">
              <button class="border-2 border-gray-300 hover:border-gray-400 text-gray-700 font-eina04 font-semibold py-3 px-6 rounded-lg transition-colors">
                Secondary Button
              </button>
              <div class="text-sm font-mono text-gray-600">
                border-2 border-gray-300 hover:border-gray-400 text-gray-700 font-eina04 font-semibold py-3 px-6 rounded-lg transition-colors
              </div>
            </div>
          </div>
          <div>
            <h4 class="text-lg font-semibold mb-4">Text Buttons</h4>
            <div class="space-y-4">
              <button class="text-gray-700 hover:text-gray-900 font-eina04 font-semibold py-3 px-6 transition-colors">
                Text Button
              </button>
              <div class="text-sm font-mono text-gray-600">
                text-gray-700 hover:text-gray-900 font-eina04 font-semibold py-3 px-6 transition-colors
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Cards -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Cards</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h4 class="text-lg font-semibold mb-4">Basic Card</h4>
            <div class="bg-white rounded-lg shadow-lg p-6 border border-gray-200">
              <h5 class="text-xl font-eina03 font-semibold mb-3">Card Title</h5>
              <p class="text-gray-600 font-eina03 mb-4">This is a basic card with shadow and border styling.</p>
              <button class="text-gray-700 hover:text-gray-900 font-eina04 font-medium">Learn More →</button>
            </div>
            <div class="text-sm font-mono text-gray-600 mt-2">
              bg-white rounded-lg shadow-lg p-6 border border-gray-200
            </div>
          </div>
          <div>
            <h4 class="text-lg font-semibold mb-4">Hover Card</h4>
            <div class="bg-white rounded-lg shadow-md hover:shadow-xl p-6 border border-gray-200 transition-shadow cursor-pointer">
              <h5 class="text-xl font-eina03 font-semibold mb-3">Interactive Card</h5>
              <p class="text-gray-600 font-eina03 mb-4">This card has hover effects and transitions.</p>
              <span class="text-gray-700 font-eina04 font-medium">Click to explore →</span>
            </div>
            <div class="text-sm font-mono text-gray-600 mt-2">
              bg-white rounded-lg shadow-md hover:shadow-xl p-6 transition-shadow
            </div>
          </div>
        </div>
      </div>

      <!-- Forms -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Form Elements</h3>
        <div class="max-w-2xl">
          <div class="space-y-6">
            <div>
              <label class="block text-sm font-eina04 font-medium text-gray-700 mb-2">Input Field</label>
              <input type="text" placeholder="Enter text here..." class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-gray-900 focus:outline-none font-eina03">
              <div class="text-sm font-mono text-gray-600 mt-2">
                w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-gray-900 focus:outline-none
              </div>
            </div>
            <div>
              <label class="block text-sm font-eina04 font-medium text-gray-700 mb-2">Textarea</label>
              <textarea placeholder="Enter message..." rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-gray-900 focus:outline-none font-eina03"></textarea>
            </div>
            <div>
              <label class="block text-sm font-eina04 font-medium text-gray-700 mb-2">Select Dropdown</label>
              <select class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-gray-900 focus:outline-none font-eina03">
                <option>Choose an option</option>
                <option>Option 1</option>
                <option>Option 2</option>
              </select>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Interactions Section -->
    <section id="interactions" class="mb-20">
      <h2 class="text-5xl font-eina02 font-semibold mb-12">Interactions</h2>
      
      <div class="mb-8">
        <p class="text-lg font-eina03 text-gray-600 max-w-3xl">
          Interaction states maintain the minimal design philosophy while providing clear feedback to users. 
          All hover and focus states use subtle grayscale transitions, with the single accent color reserved for critical focus states.
        </p>
      </div>

      <!-- Hover States -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Hover States</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div>
            <h4 class="text-lg font-semibold mb-4">Button Hovers</h4>
            <div class="space-y-4">
              <button class="bg-gray-900 hover:bg-gray-800 text-white font-eina04 font-semibold py-3 px-6 rounded-lg transition-all duration-200 transform hover:scale-105">
                Hover Me
              </button>
              <button class="border-2 border-gray-300 hover:border-gray-400 hover:bg-gray-50 text-gray-700 font-eina04 font-semibold py-3 px-6 rounded-lg transition-all duration-200">
                Secondary Hover
              </button>
              <div class="text-sm font-mono text-gray-600">
                transition-all duration-200 transform hover:scale-105
              </div>
            </div>
          </div>
          
          <div>
            <h4 class="text-lg font-semibold mb-4">Card Hovers</h4>
            <div class="bg-white rounded-lg shadow-md hover:shadow-xl p-4 border border-gray-200 transition-all duration-300 cursor-pointer hover:-translate-y-1">
              <h5 class="text-lg font-eina03 font-semibold mb-2">Hover Card</h5>
              <p class="text-gray-600 font-eina03 text-sm">Subtle lift and shadow increase</p>
            </div>
            <div class="text-sm font-mono text-gray-600 mt-2">
              hover:shadow-xl hover:-translate-y-1 transition-all duration-300
            </div>
          </div>
          
          <div>
            <h4 class="text-lg font-semibold mb-4">Link Hovers</h4>
            <div class="space-y-3">
              <a href="#" class="block text-gray-700 hover:text-gray-900 font-eina03 transition-colors duration-200">
                Simple link hover
              </a>
              <a href="#" class="block text-gray-700 hover:text-gray-900 font-eina03 border-b border-transparent hover:border-gray-300 transition-all duration-200">
                Link with underline
              </a>
              <a href="#" class="block text-gray-700 hover:text-gray-900 font-eina03 relative overflow-hidden transition-colors duration-200 hover:bg-gray-50 px-2 py-1 rounded">
                Background hover
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Focus States -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Focus States</h3>
        <div class="max-w-4xl">
          <div class="mb-6">
            <p class="text-gray-600 font-eina03 mb-4">
              Focus states use our single accent color (gray-900) to create clear accessibility indicators. 
              All interactive elements have visible focus rings that meet WCAG guidelines.
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <h4 class="text-lg font-semibold mb-4">Form Focus</h4>
              <div class="space-y-4">
                <input type="text" placeholder="Click to focus" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-gray-900 focus:outline-none font-eina03 transition-all duration-200">
                <textarea placeholder="Focus state example" rows="3" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-gray-900 focus:outline-none font-eina03 transition-all duration-200"></textarea>
                <div class="text-sm font-mono text-gray-600">
                  focus:ring-2 focus:ring-gray-900 focus:border-gray-900 focus:outline-none
                </div>
              </div>
            </div>
            
            <div>
              <h4 class="text-lg font-semibold mb-4">Button Focus</h4>
              <div class="space-y-4">
                <button class="bg-gray-900 hover:bg-gray-800 focus:bg-gray-800 focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 text-white font-eina04 font-semibold py-3 px-6 rounded-lg transition-all duration-200">
                  Primary Focus
                </button>
                <button class="border-2 border-gray-300 hover:border-gray-400 focus:border-gray-900 focus:ring-2 focus:ring-gray-900 focus:ring-offset-2 text-gray-700 font-eina04 font-semibold py-3 px-6 rounded-lg transition-all duration-200">
                  Secondary Focus
                </button>
                <div class="text-sm font-mono text-gray-600">
                  focus:ring-2 focus:ring-gray-900 focus:ring-offset-2
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Active States -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Active States</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h4 class="text-lg font-semibold mb-4">Button Active</h4>
            <div class="space-y-4">
              <button class="bg-gray-900 hover:bg-gray-800 active:bg-gray-950 text-white font-eina04 font-semibold py-3 px-6 rounded-lg transition-all duration-150 active:scale-95">
                Press Me
              </button>
              <div class="text-sm font-mono text-gray-600">
                active:bg-gray-950 active:scale-95 transition-all duration-150
              </div>
            </div>
          </div>
          
          <div>
            <h4 class="text-lg font-semibold mb-4">Navigation Active</h4>
            <nav class="space-y-2">
              <a href="#" class="block px-4 py-2 text-gray-700 hover:text-gray-900 hover:bg-gray-50 rounded-lg transition-colors duration-200">
                Normal Link
              </a>
              <a href="#" class="block px-4 py-2 bg-gray-100 text-gray-900 font-medium rounded-lg border-l-4 border-gray-900">
                Active Link
              </a>
              <a href="#" class="block px-4 py-2 text-gray-700 hover:text-gray-900 hover:bg-gray-50 rounded-lg transition-colors duration-200">
                Another Link
              </a>
            </nav>
          </div>
        </div>
      </div>

      <!-- Disabled States -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Disabled States</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h4 class="text-lg font-semibold mb-4">Disabled Buttons</h4>
            <div class="space-y-4">
              <button disabled class="bg-gray-300 text-gray-500 font-eina04 font-semibold py-3 px-6 rounded-lg cursor-not-allowed">
                Disabled Primary
              </button>
              <button disabled class="border-2 border-gray-200 text-gray-400 font-eina04 font-semibold py-3 px-6 rounded-lg cursor-not-allowed">
                Disabled Secondary
              </button>
              <div class="text-sm font-mono text-gray-600">
                bg-gray-300 text-gray-500 cursor-not-allowed
              </div>
            </div>
          </div>
          
          <div>
            <h4 class="text-lg font-semibold mb-4">Disabled Form</h4>
            <div class="space-y-4">
              <input type="text" disabled placeholder="Disabled input" class="w-full px-4 py-3 border border-gray-200 rounded-lg bg-gray-50 text-gray-400 cursor-not-allowed focus:outline-none font-eina03">
              <select disabled class="w-full px-4 py-3 border border-gray-200 rounded-lg bg-gray-50 text-gray-400 cursor-not-allowed focus:outline-none font-eina03">
                <option>Disabled select</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Loading States -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Loading States</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h4 class="text-lg font-semibold mb-4">Loading Buttons</h4>
            <div class="space-y-4">
              <button class="bg-gray-900 text-white font-eina04 font-semibold py-3 px-6 rounded-lg flex items-center gap-3">
                <div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
                Loading...
              </button>
              <div class="text-sm font-mono text-gray-600">
                border-2 border-white border-t-transparent animate-spin
              </div>
            </div>
          </div>
          
          <div>
            <h4 class="text-lg font-semibold mb-4">Content Loading</h4>
            <div class="space-y-3">
              <div class="h-4 bg-gray-200 rounded animate-pulse"></div>
              <div class="h-4 bg-gray-200 rounded animate-pulse w-3/4"></div>
              <div class="h-4 bg-gray-200 rounded animate-pulse w-1/2"></div>
              <div class="text-sm font-mono text-gray-600 mt-3">
                bg-gray-200 animate-pulse
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Interaction Guidelines -->
      <div class="mb-12">
        <h3 class="text-3xl font-eina03 font-medium mb-8">Interaction Guidelines</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="p-6 bg-white border border-gray-100 rounded-lg">
            <h4 class="text-lg font-semibold mb-4 text-gray-900">Timing & Easing</h4>
            <ul class="text-sm space-y-2 text-gray-700 font-eina03">
              <li>• <code class="text-xs bg-gray-100 px-1 rounded">duration-200</code> - Quick interactions (hover, focus)</li>
              <li>• <code class="text-xs bg-gray-100 px-1 rounded">duration-300</code> - Card hovers, layout shifts</li>
              <li>• <code class="text-xs bg-gray-100 px-1 rounded">duration-150</code> - Active/pressed states</li>
              <li>• <code class="text-xs bg-gray-100 px-1 rounded">ease-in-out</code> - Default easing</li>
            </ul>
          </div>
          <div class="p-6 bg-white border border-gray-100 rounded-lg">
            <h4 class="text-lg font-semibold mb-4 text-gray-900">Accessibility</h4>
            <ul class="text-sm space-y-2 text-gray-700 font-eina03">
              <li>• Always include focus states with visible rings</li>
              <li>• Use <code class="text-xs bg-gray-100 px-1 rounded">focus:ring-offset-2</code> for buttons</li>
              <li>• Respect <code class="text-xs bg-gray-100 px-1 rounded">prefers-reduced-motion</code></li>
              <li>• Maintain minimum 44px touch targets</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Usage Guidelines -->
    <section class="mb-20">
      <h2 class="text-5xl font-eina02 font-semibold mb-12">Usage Guidelines</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-8 bg-gray-50 rounded-lg border border-gray-200 shadow-sm">
          <h3 class="text-2xl font-eina03 font-semibold text-gray-900 mb-6">✅ White Canvas Principles</h3>
          <ul class="space-y-3 text-gray-700 font-eina03">
            <li>• Use Eina01 for hero headlines and display text</li>
            <li>• Use Eina03 for body text and content</li>
            <li>• Prioritize grayscale over color</li>
            <li>• Maintain generous white space</li>
            <li>• Use the single accent color sparingly</li>
            <li>• Let artist content be the primary visual element</li>
          </ul>
        </div>
        
        <div class="p-8 bg-gray-100 rounded-lg border border-gray-300 shadow-sm">
          <h3 class="text-2xl font-eina03 font-semibold text-gray-900 mb-6">❌ Avoid</h3>
          <ul class="space-y-3 text-gray-700 font-eina03">
            <li>• Competing with artist content visually</li>
            <li>• Using multiple bright colors</li>
            <li>• Overcrowded interfaces</li>
            <li>• Missing hover and focus states</li>
            <li>• Breaking the established neutral palette</li>
            <li>• Complex visual elements that distract</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-gray-200 pt-12 text-center">
      <p class="text-gray-600 font-eina03">
        Espace29 Design System — A white canvas for artistic expression
      </p>
      <p class="text-sm text-gray-500 mt-2 font-eina04">
        Minimal design that prioritizes artist content over interface decoration
      </p>
    </footer>
  </main>
</Layout>
