---
import Layout from "@layouts/Layout.astro"
import PageTopLayout from "@layouts/PageTopLayout.astro"
import { artists, type Artist, formatArtistName } from "@lib/artists-helper"

export function getStaticPaths() {
  return artists.map((artist) => ({
    params: { slug: artist.slug },
    props: { artist },
  }))
}

const { artist } = Astro.props

if (!artist) {
  return Astro.redirect("/404")
}

const formattedName = formatArtistName(artist)
---

<Layout title={`e29 | ${formattedName}`}>
  <main class="min-h-full w-full flex flex-col items-start">
    <PageTopLayout title={formattedName} />
    <section class="w-full h-screen flex flex-col md:flex-row">
      <!-- Left side - Image Carousel -->
      <div class="flex-1 bg-gray-50 flex items-center justify-center p-8">
        <div class="w-full h-full max-w-2xl max-h-[80vh] relative">
          {artist.profileImageUrlList[0] && (
            <img
              src={artist.profileImageUrlList[0].url}
              alt={artist.profileImageUrlList[0].alt}
              class="w-full h-full object-cover rounded-lg shadow-md transition-all duration-300"
              loading="lazy"
            />
          )}
          
          <!-- Image navigation dots (if multiple images) -->
          {artist.profileImageUrlList.length > 1 && (
            <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-2">
              {artist.profileImageUrlList.map((_, index) => (
                <button
                  class="w-3 h-3 rounded-full transition-all duration-200"
                  class:list={[
                    index === 0 ? 'bg-gray-900' : 'bg-gray-400 hover:bg-gray-600'
                  ]}
                  aria-label={`Image ${index + 1}`}
                />
              ))}
            </div>
          )}
        </div>
      </div>

      <!-- Right side - Artist Details -->
      <div class="flex-1 bg-white p-8 flex flex-col justify-center">
        <div class="max-w-lg space-y-8">
          
          <!-- Artist Title -->
          <div class="border-b border-gray-200 pb-6">
            <h2 class="text-4xl font-eina02 font-semibold text-gray-900 mb-3">
              {artist.title}
            </h2>
            <p class="text-xl font-eina03 text-gray-600">
              {formattedName}
            </p>
          </div>

          <!-- Website Link -->
          {artist.websiteUrl && (
            <div class="border-b border-gray-200 pb-6">
              <h3 class="text-lg font-eina04 font-semibold text-gray-900 mb-3">
                Site Web
              </h3>
              <a 
                href={artist.websiteUrl} 
                target="_blank" 
                rel="noopener noreferrer"
                class="text-gray-700 hover:text-gray-900 font-eina03 transition-colors duration-200 border-b border-transparent hover:border-gray-300"
              >
                {artist.websiteUrl}
              </a>
            </div>
          )}

          <!-- Email -->
          {artist.email && (
            <div class="border-b border-gray-200 pb-6">
              <h3 class="text-lg font-eina04 font-semibold text-gray-900 mb-3">
                Contact
              </h3>
              <a 
                href={`mailto:${artist.email}`}
                class="text-gray-700 hover:text-gray-900 font-eina03 transition-colors duration-200 border-b border-transparent hover:border-gray-300"
              >
                {artist.email}
              </a>
            </div>
          )}

          <!-- Description -->
          <div>
            <h3 class="text-lg font-eina04 font-semibold text-gray-900 mb-4">
              À propos
            </h3>
            <div class="space-y-4 max-h-64 overflow-y-auto">
              {artist.profileDescription.split('\n\n').map((paragraph) => (
                <p class="text-lg font-eina03 leading-relaxed text-gray-700">
                  {paragraph.trim()}
                </p>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>
  </main>
</Layout>
