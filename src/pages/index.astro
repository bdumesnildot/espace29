---
import Layout from "@layouts/Layout.astro"
import galleryImage from "@assets/e29-gallery.webp"
---

<Layout title="e29 | Accueil">
  <main class="flex h-[calc(100vh-60px)]">
    <div class="hero-image-container relative flex-1">
      <img
        src={galleryImage.src}
        alt="Espace 29 Gallery"
        class="h-full w-full object-cover"
      />
      <div
        class="absolute inset-0 flex items-center justify-center bg-gray-900/40"
      >
        <h1
          class="font-eina01 text-6xl font-semibold text-white drop-shadow-lg md:text-8xl"
        >
          espace29
        </h1>
      </div>
    </div>
  </main>
</Layout>

<script>
  const secret = "e29"
  let buffer = ""
  let resetTimer: ReturnType<typeof setTimeout> | null = null

  document.addEventListener("keydown", (e) => {
    if (e.key.length !== 1) return
    if (e.ctrlKey || e.metaKey || e.altKey) return

    buffer += e.key.toLowerCase()

    if (resetTimer) clearTimeout(resetTimer)
    resetTimer = setTimeout(() => {
      buffer = ""
    }, 2000)

    if (buffer === secret) {
      buffer = ""
      if (resetTimer) clearTimeout(resetTimer)
      window.location.href = "/void"
    }

    if (!secret.startsWith(buffer)) {
      buffer = ""
    }
  })
</script>
